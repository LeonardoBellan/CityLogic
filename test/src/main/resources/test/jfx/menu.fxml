<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>

<StackPane xmlns="http://javafx.com/javafx/8.0.171"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="test.jfx.menuController"
           styleClass="root-pane"
           stylesheets="@styles.css">

    <VBox alignment="CENTER" spacing="16" maxWidth="300" maxHeight="400"
          styleClass="card">

        <Label text="Simcity Lite" styleClass="title-label"/>

        <Separator styleClass="separator-primary" prefWidth="200"/>

        <Button fx:id="startButton" text="New Game" onAction="#startNewGame"
                prefWidth="180" styleClass="btn,btn-primary"/>

        <Button fx:id="loadButton" text="Load Game" onAction="#loadGame"
                prefWidth="180" styleClass="btn,btn-secondary"/>

        <Button fx:id="exitButton" text="Exit" onAction="#exitGame"
                prefWidth="180" styleClass="btn,btn-danger"/>
    </VBox>
</StackPane>
